---
import MainHead from "./MainHead.astro";
import Icon from "../components/Icon.astro";
import NoiseOverlay from "../components/NoiseOverlay.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

const { title, seoTitle, seoDesc } = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/Portfolio_site/", label: "Home" },
  { href: "/Portfolio_site/about", label: "About" },
  { href: "/Portfolio_site/projects", label: "Projects" },
  { href: "/Portfolio_site/resume", label: "Resume" }
];

const isActive = (href: string) => {
  if (href === "/Portfolio_site/") {
    return currentPath === href || currentPath === "/Portfolio_site";
  }
  return currentPath.startsWith(href);
};
---

<html lang="en" class="scroll-smooth">
  <MainHead title={title} seoTitle={seoTitle} seoDesc={seoDesc} />
  <body class="bg-bg text-text-primary min-h-screen font-body antialiased">
    <nav id="main-nav" class="fixed top-0 w-full z-50 border-b border-transparent">
      <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
        <div class="flex justify-between items-center h-16 md:h-20">
          <a href="/Portfolio_site/" class="font-display font-bold text-lg tracking-tight text-text-primary hover:text-text-body transition-colors">
            AKP
          </a>

          <div class="hidden md:flex items-center gap-1">
            {navItems.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  "relative px-4 py-2 text-sm font-medium transition-colors duration-200",
                  isActive(href) ? "text-accent" : "text-text-muted hover:text-text-primary"
                ]}
              >
                {label}
                {isActive(href) && (
                  <span class="absolute bottom-0 left-4 right-4 h-0.5 bg-accent rounded-full"></span>
                )}
              </a>
            ))}
          </div>

          <div class="flex items-center gap-1">
            <ThemeToggle />
            <a href="https://github.com/abhilashpanda04" target="_blank" rel="noopener noreferrer" class="touch-min text-text-muted hover:text-text-primary transition-colors" aria-label="GitHub">
              <Icon name="github" class="h-5 w-5" size={20} />
            </a>
            <a href="https://linkedin.com/in/abhilash-k-panda" target="_blank" rel="noopener noreferrer" class="touch-min text-text-muted hover:text-text-primary transition-colors" aria-label="LinkedIn">
              <Icon name="linkedin" class="h-5 w-5" size={20} />
            </a>
            <button type="button" id="mobile-menu-btn" class="md:hidden touch-min text-text-muted hover:text-text-primary transition-colors" aria-label="Toggle menu" aria-expanded="false">
              <Icon name="menu" id="icon-menu" class="h-6 w-6" size={24} />
              <Icon name="close" id="icon-close" class="h-6 w-6 hidden" size={24} />
            </button>
          </div>
        </div>
      </div>

      <div id="mobile-menu" class="md:hidden fixed inset-0 top-16 bg-surface z-40 hidden" hidden>
        <div class="flex flex-col items-center justify-center h-full gap-8">
          {navItems.map(({ href, label }) => (
            <a href={href} class:list={["text-2xl font-display font-medium transition-colors duration-200", isActive(href) ? "text-text-primary" : "text-text-muted hover:text-text-primary"]}>
              {label}
            </a>
          ))}
          <div class="flex items-center gap-6 mt-8">
            <ThemeToggle />
            <a href="https://github.com/abhilashpanda04" target="_blank" rel="noopener noreferrer" class="touch-min text-text-muted hover:text-text-primary transition-colors" aria-label="GitHub">
              <Icon name="github" class="h-6 w-6" size={24} />
            </a>
            <a href="https://linkedin.com/in/abhilash-k-panda" target="_blank" rel="noopener noreferrer" class="touch-min text-text-muted hover:text-text-primary transition-colors" aria-label="LinkedIn">
              <Icon name="linkedin" class="h-6 w-6" size={24} />
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main class="relative z-10">
      <slot />
    </main>

    <footer class="border-t border-border">
      <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="text-center md:text-left">
            <p class="font-display font-medium text-text-primary">Abhilash Kumar Panda</p>
            <p class="font-mono text-caption text-text-muted mt-1">Senior Data Scientist · GenAI & Agentic Systems · LLMOps</p>
          </div>
          <div class="flex items-center gap-6 font-mono text-caption text-text-muted">
            <a href="mailto:abhilash.k.panda@gmail.com" class="hover:text-text-primary transition-colors">Email</a>
            <a href="https://linkedin.com/in/abhilash-k-panda" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors">LinkedIn</a>
            <a href="https://github.com/abhilashpanda04" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors">GitHub</a>
          </div>
        </div>
        <p class="text-center md:text-left font-mono text-caption text-text-muted mt-8">© {new Date().getFullYear()} Abhilash Kumar Panda. All rights reserved.</p>
      </div>
    </footer>

    <NoiseOverlay />
    <script src="/Portfolio_site/main.js" defer is:inline></script>
  </body>
</html>

---
export interface Props {
  variant?: 'primary' | 'secondary';
  href?: string;
  class?: string;
  target?: string;
  rel?: string;
  download?: boolean | string;
}

const { variant = 'primary', href, class: className = '', target, rel, download } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-display font-medium transition-all duration-200 ease-out';
const variants = {
  primary: 'bg-accent text-white hover:bg-accent-hover shadow-[0_0_20px_rgba(99,102,241,0.15)] hover:shadow-[0_0_28px_rgba(99,102,241,0.25)]',
  secondary: 'bg-transparent text-text-primary border border-border hover:border-accent hover:text-accent',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel} download={download}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}

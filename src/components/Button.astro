---
export interface Props {
  variant?: 'primary' | 'secondary';
  href?: string;
  class?: string;
  target?: string;
  rel?: string;
  download?: boolean | string;
}

const { variant = 'primary', href, class: className = '', target, rel, download } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-display font-medium transition-all duration-150 ease-out';
const variants = {
  primary: 'bg-white text-bg hover:bg-[#d4d4d4]',
  secondary: 'bg-transparent text-text-primary border border-border hover:border-border-strong hover:bg-white/[0.04]',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel} download={download}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}

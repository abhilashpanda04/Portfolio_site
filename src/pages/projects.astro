---
import MainLayout from "../layout/MainLayout.astro";
import Icon from "../components/Icon.astro";
import SectionLabel from "../components/SectionLabel.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";

const title = "Projects | Abhilash Kumar Panda";
const seoTitle = "Projects | Abhilash Kumar Panda";
const seoDesc = "Production AI projects in financial data extraction, RAG, document intelligence, and agentic systems.";

const projects = [
  {
    number: "01",
    tag: "GenAI · Production",
    title: "GenAI Financial Data Extraction Pipeline",
    impact: "£350K+ saved · 50 FTE reduction",
    story: [
      { label: "Challenge", text: "Broker reports hold critical data, but formats vary and standard extraction misses the financial semantics." },
      { label: "Approach", text: "Meta-prompting + PydanticAI, designed by someone who has read hundreds of these reports." },
      { label: "Outcome", text: "High-accuracy structured extraction at scale, eliminating 50 FTEs of manual work." }
    ],
    tech: ["LangChain", "PydanticAI", "GPT-4", "Meta-prompting", "Python"]
  },
  {
    number: "02",
    tag: "RAG · Production",
    title: "Context-Aware RAG Answer Engine",
    impact: "Source-referenced · Session memory · Analyst-grade",
    story: [
      { label: "Challenge", text: "Financial analysts need reliable answers, but LLMs hallucinate and compliance demands auditability." },
      { label: "Approach", text: "Source-referenced RAG with session memory; prompts shaped by real analyst query patterns." },
      { label: "Outcome", text: "Analysts get answers they can trace back to source documents across multi-turn workflows." }
    ],
    tech: ["RAG", "LangChain", "Vector DB", "Prompt Engineering", "Session Memory"]
  },
  {
    number: "03",
    tag: "Document Intelligence · Production",
    title: "Korean Regulatory Filing Extraction",
    impact: "15 days → 40 minutes · 130K+ documents · £250K+ saved",
    story: [
      { label: "Challenge", text: "Korean regulatory filings in non-Latin script, high volume, tight accuracy requirements." },
      { label: "Approach", text: "End-to-end NLP pipeline with domain-tuned classification and extraction rules." },
      { label: "Outcome", text: "85%+ hit rate across 130K+ docs, 5 FTE reduction, processing cut from 15 days to 40 minutes." }
    ],
    tech: ["Python", "NLP", "Cosine Similarity", "Two-stage Classification", "BeautifulSoup"]
  },
  {
    number: "04",
    tag: "Agentic AI · Research",
    title: "Multi-Agent Financial Document Intelligence PoC",
    impact: "Executive-endorsed · LangGraph orchestration",
    story: [
      { label: "Challenge", text: "Complex financial documents need reasoning, routing, and multi-step validation beyond a single prompt." },
      { label: "Approach", text: "LangGraph multi-agent architecture designed around real document types and analyst workflows." },
      { label: "Outcome", text: "PoC earned regional executive endorsement and demonstrated a path to autonomous document intelligence." }
    ],
    tech: ["LangGraph", "Agentic AI", "LLM", "Financial NLP", "Python"]
  },
  {
    number: "05",
    tag: "Document Intelligence · Production",
    title: "Image-Based Document Intelligence Pipeline",
    impact: "0% → 64% image coverage · 5 FTE eliminated",
    story: [
      { label: "Challenge", text: "A large class of financial documents existed only as images, completely outside automation reach." },
      { label: "Approach", text: "Two-stage pipeline: Azure Layout Model for structure + Python rules for financial semantics." },
      { label: "Outcome", text: "Coverage expanded from 0% to 64%, unlocking a new automation surface and eliminating 5 FTEs." }
    ],
    tech: ["Azure Document Intelligence", "Azure Layout Model", "Python", "Rules Engine"]
  },
  {
    number: "06",
    tag: "ML · Production",
    title: "Hybrid ML Ingestion Pipeline",
    impact: "5 markets · 3 FTE saved · 50% scope reduction",
    story: [
      { label: "Challenge", text: "Ingesting financial documents across five markets with inconsistent formats and noisy boundaries." },
      { label: "Approach", text: "Cosine similarity + two-stage classification, with rule-based edge cases handled by domain expertise." },
      { label: "Outcome", text: "3 FTEs saved, 50% reduction in out-of-scope data, reliable ingestion across CA, IN, US, AU." }
    ],
    tech: ["Cosine Similarity", "Two-stage Classification", "FastAPI", "HuggingFace", "S-BERT"]
  }
];
---

<MainLayout title={title} seoTitle={seoTitle} seoDesc={seoDesc}>
  <section class="pt-32 md:pt-40 pb-24">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal>
        <SectionLabel index="Work" label="Projects" />
        
        <h1 class="font-display text-headline md:text-display text-text-primary max-w-3xl">
          Production work that proves the thesis
        </h1>
        
        <p class="mt-6 text-body text-text-body max-w-prose">
          Every project follows the same pattern: start with the financial workflow, understand where it breaks, then build AI that fixes it at scale. Not demos — systems.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="pb-24 md:pb-32">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <div class="border-t border-border">
        {projects.map((p, i) => (
          <Reveal delay={`${i * 80}ms`} as="article" class="project-row group border-b border-border">
            <button
              type="button"
              class="w-full py-8 md:py-10 flex items-start gap-6 md:gap-10 text-left transition-colors duration-200 hover:bg-surface"
              aria-expanded="false"
              data-project={i}
            >
              <span class="font-mono text-caption text-text-muted uppercase tracking-[0.12em] w-10 md:w-14 flex-shrink-0 pt-1">{p.number}</span>
              
              <div class="flex-1 min-w-0">
                <p class="font-mono text-caption text-text-muted uppercase tracking-[0.12em]">{p.tag}</p>
                <h3 class="mt-2 font-display text-title md:text-headline text-text-primary group-hover:text-text-body transition-colors">{p.title}</h3>
                <p class="mt-1 text-body text-text-muted">{p.impact}</p>
              </div>
              
              <span class="flex-shrink-0 mt-1">
                <Icon name="arrow-down" class="h-5 w-5 text-text-muted group-hover:text-text-primary transition-transform duration-200 project-chevron" size={20} />
              </span>
            </button>
            
            <div class="project-detail hidden px-10 md:px-24 pb-8 md:pb-10">
              <div class="grid md:grid-cols-3 gap-6 mb-6">
                {p.story.map(s => (
                  <div>
                    <p class="font-mono text-caption text-text-muted uppercase tracking-[0.12em] mb-2">{s.label}</p>
                    <p class="text-body text-text-body leading-relaxed">{s.text}</p>
                  </div>
                ))}
              </div>
              
              <div class="flex flex-wrap gap-2">
                {p.tech.map(t => (
                  <span class="px-2.5 py-1 rounded-md border border-border font-mono text-caption text-text-muted uppercase tracking-[0.08em]">{t}</span>
                ))}
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 border-t border-border">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal>
        <div class="p-8 md:p-12 rounded-2xl border border-border bg-surface">
          <div class="flex items-start gap-4">
            <span class="h-2 w-2 rounded-full bg-text-primary mt-2 flex-shrink-0"></span>
            <div class="flex-1">
              <h2 class="font-display text-title text-text-primary mb-3">Let's build the next one together</h2>
              <p class="text-body text-text-body leading-relaxed mb-6 max-w-xl">
                Seeking senior IC and lead roles in fintech, exchanges, asset management, and financial AI teams worldwide.
              </p>
              <Button href="mailto:abhilash.k.panda@gmail.com" variant="primary">
                <Icon name="mail" class="h-4 w-4" size={16} />
                abhilash.k.panda@gmail.com
              </Button>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <script is:inline>
    (function() {
      document.querySelectorAll('.project-row button').forEach(function(button) {
        const detail = button.nextElementSibling;
        const chevron = button.querySelector('.project-chevron');

        button.addEventListener('click', function() {
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          button.setAttribute('aria-expanded', String(!isExpanded));
          if (detail) detail.classList.toggle('hidden', isExpanded);
          if (chevron) chevron.classList.toggle('rotate-180', !isExpanded);
        });
      });
    })();
  </script>
</MainLayout>

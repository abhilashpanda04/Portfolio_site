---
import MainLayout from "../layout/MainLayout.astro";
---

<MainLayout
  title="Abhilash Kumar Panda — Senior Data Scientist | GenAI & Agentic Systems"
  seoTitle="Abhilash Kumar Panda | Senior Data Scientist | GenAI & LLMOps"
  seoDesc="Senior Data Scientist specialising in GenAI, Agentic Systems, RAG, and LLMOps for financial services. £600K+ business value delivered at LSEG.">

  <!-- ═══ ACT I: THE HOOK ═══ -->
  <section class="relative min-h-screen flex items-center pt-20 pb-32 overflow-hidden">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 w-full">

      <!-- Chapter marker -->
      <div class="flex items-center gap-3 mb-10 fade-in" style="animation-delay: 0.1s">
        <div class="h-px w-12 bg-gradient-to-r from-[#4461f2] to-transparent"></div>
        <span class="text-xs font-mono text-[#4461f2]/60 uppercase tracking-[0.2em]">Senior Data Scientist · Bangalore → Singapore</span>
      </div>

      <!-- Main headline -->
      <h1 class="fade-in" style="animation-delay: 0.2s">
        <span class="block text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight text-white/90 leading-[1.05]">
          Abhilash<br/>Kumar Panda
        </span>
      </h1>

      <!-- Thesis statement -->
      <p class="mt-8 text-xl sm:text-2xl text-white/50 font-light leading-relaxed max-w-2xl fade-in" style="animation-delay: 0.35s">
        I spent two years inside institutional finance reconciling pension funds.<br class="hidden sm:block"/>
        <span class="text-white/75">Most AI engineers would call that irrelevant experience.<br class="hidden sm:block"/>
        I call it an unfair advantage.</span>
      </p>

      <!-- The thesis callout -->
      <div class="mt-12 p-6 rounded-2xl bg-gradient-to-br from-[#4461f2]/10 to-[#bc52ee]/10
                  border border-[#4461f2]/20 max-w-xl fade-in" style="animation-delay: 0.5s">
        <div class="flex gap-4 items-start">
          <div class="w-1 self-stretch rounded-full bg-gradient-to-b from-[#4461f2] to-[#bc52ee] flex-shrink-0"></div>
          <p class="text-white/70 text-base leading-relaxed italic">
            "AI systems in finance fail when they're built by engineers who've never lived inside financial markets.
            I've done both — and that's the difference between AI that looks good in demos and AI that
            <span class="text-white/90 not-italic font-medium">delivers £600K+ in production.</span>"
          </p>
        </div>
      </div>

      <!-- Stats as proof points -->
      <div class="mt-12 flex flex-wrap gap-3 fade-in" style="animation-delay: 0.65s">
        {[
          { value: "9+", label: "Years" },
          { value: "£600K+", label: "Business value" },
          { value: "55 FTEs", label: "Automated" },
          { value: "130K+", label: "Docs processed" }
        ].map(s => (
          <div class="px-4 py-3 rounded-xl bg-white/5 border border-white/10 hover:border-[#4461f2]/30 transition-all group">
            <span class="text-lg font-bold text-white group-hover:bg-clip-text group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-[#4461f2] group-hover:to-[#bc52ee] transition-all">{s.value}</span>
            <span class="text-white/35 text-sm ml-2">{s.label}</span>
          </div>
        ))}
      </div>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap gap-4 fade-in" style="animation-delay: 0.8s">
        <a href="/Portfolio_site/projects"
           class="px-6 py-3 rounded-lg bg-gradient-to-r from-[#4461f2] to-[#bc52ee] text-white font-medium
                  hover:opacity-90 hover:-translate-y-0.5 transition-all shadow-lg shadow-[#4461f2]/20">
          See the work →
        </a>
        <a href="/Portfolio_site/about"
           class="px-6 py-3 rounded-lg border border-white/10 text-white/70 font-medium
                  hover:bg-white/5 hover:text-white hover:border-white/20 transition-all">
          Read my story
        </a>
        <a href="mailto:abhilash.k.panda@gmail.com"
           class="px-6 py-3 rounded-lg text-white/50 font-medium hover:text-white/80 transition-all">
          Get in touch ↗
        </a>
      </div>

    </div>

    <!-- Decorative large background text -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 text-[200px] font-black text-white/[0.015] select-none pointer-events-none leading-none hidden xl:block">
      AI
    </div>
  </section>

  <!-- ═══ ACT II: THE JOURNEY ═══ -->
  <section class="py-24 border-t border-white/5 relative">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      <div class="flex items-center gap-4 mb-4">
        <span class="text-xs font-mono text-white/25 uppercase tracking-[0.2em]">01 / The Journey</span>
        <div class="h-px flex-1 bg-white/5"></div>
      </div>
      <h2 class="text-3xl font-bold text-white mb-3">From the desk to the model layer</h2>
      <p class="text-white/45 mb-14 max-w-2xl">Three chapters. Each one built on the last.</p>

      <div class="relative">
        <!-- Connecting line -->
        <div class="absolute left-8 top-8 bottom-8 w-px bg-gradient-to-b from-[#4461f2] via-[#8b5cf6] to-[#bc52ee] opacity-30 hidden md:block"></div>

        <div class="space-y-6">

          <!-- Chapter 1 -->
          <div class="journey-card group md:pl-20 relative">
            <div class="hidden md:flex absolute left-4 top-6 h-8 w-8 rounded-full bg-[#000212] border-2 border-[#4461f2]/60
                        items-center justify-center text-xs font-bold text-[#4461f2] group-hover:border-[#4461f2] transition-colors">
              1
            </div>
            <div class="p-6 rounded-xl bg-white/5 border border-white/10 hover:border-[#4461f2]/30 transition-all duration-500 group-hover:bg-white/[0.07]">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <div>
                  <span class="text-xs font-mono text-white/25 uppercase tracking-wider">Feb 2017 – Oct 2019</span>
                  <h3 class="text-lg font-semibold text-white mt-1">Reconciliation Analyst</h3>
                  <p class="text-[#4461f2]/70 text-sm">State Street Global Advisory</p>
                </div>
                <span class="px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400/80 text-xs font-medium">
                  Domain Foundation
                </span>
              </div>
              <p class="text-white/50 text-sm leading-relaxed">
                100+ pension fund portfolios. Bloomberg Terminal, Refinitiv Eikon, SmartStream TLM. Daily reconciliation of
                equities, derivatives, and FX across global custodians. This wasn't background noise —
                <span class="text-white/70">this became the domain knowledge that made every AI system at LSEG actually work.</span>
              </p>
            </div>
          </div>

          <!-- Chapter 2 -->
          <div class="journey-card group md:pl-20 relative">
            <div class="hidden md:flex absolute left-4 top-6 h-8 w-8 rounded-full bg-[#000212] border-2 border-[#7c8bff]/60
                        items-center justify-center text-xs font-bold text-[#7c8bff] group-hover:border-[#7c8bff] transition-colors">
              2
            </div>
            <div class="p-6 rounded-xl bg-white/5 border border-white/10 hover:border-[#7c8bff]/30 transition-all duration-500 group-hover:bg-white/[0.07]">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <div>
                  <span class="text-xs font-mono text-white/25 uppercase tracking-wider">Nov 2019 – Oct 2022</span>
                  <h3 class="text-lg font-semibold text-white mt-1">Data Scientist</h3>
                  <p class="text-[#7c8bff]/70 text-sm">London Stock Exchange Group</p>
                </div>
                <span class="px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400/80 text-xs font-medium">
                  Applied ML
                </span>
              </div>
              <p class="text-white/50 text-sm leading-relaxed">
                Turned domain expertise into real pipelines. Korean regulatory filings — 130K+ documents, processing cut from
                15 days to 40 minutes, £250K+ saved. Azure Document Intelligence pipelines expanding coverage from 0% to 64%.
                <span class="text-white/70">Proof that knowing the domain first makes better ML engineers.</span>
              </p>
            </div>
          </div>

          <!-- Chapter 3 -->
          <div class="journey-card group md:pl-20 relative">
            <div class="hidden md:flex absolute left-4 top-6 h-8 w-8 rounded-full bg-[#000212] border-2 border-[#bc52ee]/60
                        items-center justify-center text-xs font-bold text-[#bc52ee] group-hover:border-[#bc52ee] transition-colors">
              3
            </div>
            <div class="p-6 rounded-xl bg-white/5 border border-white/10 hover:border-[#bc52ee]/30 transition-all duration-500 group-hover:bg-white/[0.07]">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <div>
                  <span class="text-xs font-mono text-white/25 uppercase tracking-wider">Nov 2022 – Present</span>
                  <h3 class="text-lg font-semibold text-white mt-1">Senior Data Scientist</h3>
                  <p class="text-[#bc52ee]/70 text-sm">London Stock Exchange Group</p>
                </div>
                <span class="px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-400/80 text-xs font-medium">
                  GenAI Leadership
                </span>
              </div>
              <p class="text-white/50 text-sm leading-relaxed">
                GenAI extraction pipelines (PydanticAI, meta-prompting), context-aware RAG engines, multi-agent PoC that earned
                executive endorsement. £350K+ delivered. 50 FTE eliminated.
                <span class="text-white/70">All of it commercially accurate because it was built with financial domain knowledge embedded from day one.</span>
              </p>
            </div>
          </div>

        </div>

        <!-- Bridge / punchline -->
        <div class="mt-10 pl-0 md:pl-20">
          <a href="/Portfolio_site/about"
             class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/80 transition-colors group">
            Read the full story
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ACT III: THE PROOF ═══ -->
  <section class="py-24 border-t border-white/5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      <div class="flex items-center gap-4 mb-4">
        <span class="text-xs font-mono text-white/25 uppercase tracking-[0.2em]">02 / The Proof</span>
        <div class="h-px flex-1 bg-white/5"></div>
      </div>
      <h2 class="text-3xl font-bold text-white mb-3">What this looks like in production</h2>
      <p class="text-white/45 mb-14 max-w-2xl">Not demos. Not prototypes. Systems running in global financial workflows.</p>

      <div class="grid gap-6 lg:grid-cols-3">

        {[
          {
            tag: "GenAI · Production",
            title: "Financial Data Extraction Pipeline",
            pull: "£350K+ saved. 50 FTEs automated.",
            body: "Meta-prompting + PydanticAI for structured extraction from broker reports. High accuracy because the prompts were designed by someone who's read hundreds of these reports.",
            tech: ["LangChain", "PydanticAI", "GPT-4", "Meta-prompting"],
            color: "from-[#4461f2]"
          },
          {
            tag: "RAG · Production",
            title: "Context-Aware Answer Engine",
            pull: "Source-referenced. Session memory. Built for analysts.",
            body: "RAG system designed for financial analysts — not generic QA. Source-referenced responses because financial compliance demands it. Session memory because analysts work in multi-turn workflows.",
            tech: ["RAG", "LangChain", "Vector DB", "Prompt Engineering"],
            color: "from-[#7c8bff]"
          },
          {
            tag: "LLMOps · Research",
            title: "LLaMA 3.1 8B Fine-tuning",
            pull: "~60% faster inference than standard PEFT.",
            body: "Domain-adapted LLaMA 3.1 8B via Unsloth QLoRA. When you understand the financial documents you're fine-tuning on, the dataset quality is fundamentally different.",
            tech: ["LLaMA 3.1", "Unsloth", "QLoRA", "HuggingFace"],
            color: "from-[#bc52ee]"
          }
        ].map(p => (
          <div class="group flex flex-col bg-white/5 rounded-xl border border-white/10
                      hover:border-white/20 transition-all duration-500 hover:-translate-y-1 overflow-hidden">
            <div class={`h-0.5 bg-gradient-to-r ${p.color} to-transparent`}></div>
            <div class="p-6 flex flex-col flex-1">
              <span class="text-xs font-mono text-white/30 uppercase tracking-wider mb-3">{p.tag}</span>
              <h3 class="text-base font-semibold text-white mb-2 leading-snug group-hover:text-white/90">{p.title}</h3>
              <p class="text-sm font-medium text-[#7c8bff]/80 mb-3">{p.pull}</p>
              <p class="text-sm text-white/45 leading-relaxed flex-1">{p.body}</p>
              <div class="flex flex-wrap gap-1.5 mt-5">
                {p.tech.map(t => (
                  <span class="px-2 py-0.5 text-xs rounded-md bg-white/5 text-white/40 border border-white/10">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))}

      </div>

      <div class="mt-8 text-center">
        <a href="/Portfolio_site/projects"
           class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/80 transition-colors group">
          See all projects including MLOps, BERT pre-training, Chrome extensions
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ THE TOOLKIT ═══ -->
  <section class="py-24 border-t border-white/5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      <div class="flex items-center gap-4 mb-4">
        <span class="text-xs font-mono text-white/25 uppercase tracking-[0.2em]">03 / The Toolkit</span>
        <div class="h-px flex-1 bg-white/5"></div>
      </div>
      <h2 class="text-3xl font-bold text-white mb-3">What I work with</h2>
      <p class="text-white/45 mb-14 max-w-2xl">
        Accumulated across 9 years. Tools selected for production — not benchmarks.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          {
            icon: "◈",
            label: "GenAI & Agents",
            skills: ["LangChain", "LangGraph", "Pydantic-AI", "MCP", "RAG", "Vector DB", "Agentic AI"]
          },
          {
            icon: "◇",
            label: "LLMs",
            skills: ["GPT-4", "Gemini", "Claude", "LLaMA", "HuggingFace", "Unsloth", "vLLM"]
          },
          {
            icon: "△",
            label: "ML / Deep Learning",
            skills: ["PyTorch", "TensorFlow", "Scikit-learn", "NLP", "Computer Vision", "BERT"]
          },
          {
            icon: "○",
            label: "Cloud & LLMOps",
            skills: ["GCP", "Azure", "Azure Doc Intelligence", "LLMOps", "CI/CD", "MLflow", "ZenML"]
          }
        ].map(cat => (
          <div class="p-5 rounded-xl bg-white/5 border border-white/10 hover:border-[#4461f2]/25 transition-all duration-300">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-[#4461f2]/60 text-lg font-light">{cat.icon}</span>
              <h3 class="text-xs font-semibold text-white/55 uppercase tracking-wider">{cat.label}</h3>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {cat.skills.map(s => (
                <span class="px-2 py-1 text-xs rounded-lg bg-white/5 text-white/50 border border-white/10 hover:text-white/70 hover:border-white/20 transition-colors cursor-default">
                  {s}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ THE ASK ═══ -->
  <section class="py-24 border-t border-white/5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl">
        <div class="flex items-center gap-4 mb-4">
          <span class="text-xs font-mono text-white/25 uppercase tracking-[0.2em]">04 / What's next</span>
          <div class="h-px flex-1 bg-white/5"></div>
        </div>
        <h2 class="text-3xl font-bold text-white mb-4">Seeking my next chapter</h2>
        <p class="text-white/50 leading-relaxed mb-2">
          Nine years in, I'm looking to bring this combination of financial domain knowledge and GenAI engineering to
          Singapore's world-class fintech and financial services ecosystem.
        </p>
        <p class="text-white/50 leading-relaxed mb-10">
          Senior IC roles, lead positions, or advisory engagements where deep financial AI expertise matters.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="mailto:abhilash.k.panda@gmail.com"
             class="px-7 py-3.5 rounded-lg bg-gradient-to-r from-[#4461f2] to-[#bc52ee] text-white font-medium
                    hover:opacity-90 hover:-translate-y-0.5 transition-all shadow-lg shadow-[#4461f2]/20">
            abhilash.k.panda@gmail.com
          </a>
          <a href="https://linkedin.com/in/abhilash-k-panda" target="_blank" rel="noopener noreferrer"
             class="px-7 py-3.5 rounded-lg border border-white/10 text-white/70 font-medium hover:bg-white/5 hover:text-white transition-all">
            LinkedIn ↗
          </a>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.7s ease-out forwards;
  }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .journey-card {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .journey-card:nth-child(1) { animation-delay: 0.1s; }
  .journey-card:nth-child(2) { animation-delay: 0.25s; }
  .journey-card:nth-child(3) { animation-delay: 0.4s; }
</style>

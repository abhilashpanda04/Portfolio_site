---
import MainLayout from "../layout/MainLayout.astro";
import Icon from "../components/Icon.astro";
import Logo from "../components/Logo.astro";
import SectionLabel from "../components/SectionLabel.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";
import HeroOrb from "../components/HeroOrb.astro";

const title = "Abhilash Kumar Panda | Senior Data Scientist | GenAI & LLMOps";
const seoTitle = "Abhilash Kumar Panda | Senior Data Scientist | GenAI & LLMOps";
const seoDesc = "Senior Data Scientist with 9 years of experience building production AI systems for financial markets.";
---

<MainLayout title={title} seoTitle={seoTitle} seoDesc={seoDesc}>
  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col justify-center pt-20 pb-24 overflow-hidden">
    <HeroOrb />
    
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20 relative z-10">
      <div class="max-w-4xl">
        <div class="animate-hero-name">
          <h1 class="font-display text-display-xl md:text-[5.5rem] text-text-primary leading-[0.95] tracking-[-0.03em]">
            Abhilash
            <br />
            Kumar Panda
          </h1>
        </div>
        
        <div class="mt-8 animate-fade-in delay-150">
          <p class="font-mono text-caption text-text-muted uppercase tracking-[0.12em]">
            Senior Data Scientist · GenAI · LLMOps
          </p>
        </div>
        
        <div class="mt-6 max-w-2xl animate-fade-up delay-250">
          <p class="text-lg md:text-xl text-text-body leading-relaxed">
            I build production AI for financial markets — <span class="text-text-primary">by people who've read the documents it processes.</span>
          </p>
        </div>
        
        <div class="mt-10 flex flex-wrap gap-4 animate-fade-up delay-350">
          <Button href="/Portfolio_site/projects" variant="primary">
            See the work
            <Icon name="arrow-right" class="h-4 w-4" size={16} />
          </Button>
          <Button href="/Portfolio_site/about" variant="secondary">
            Read my story
          </Button>
        </div>
        
        <div class="mt-20 pt-8 border-t border-border animate-fade-up delay-450">
          <p class="font-mono text-caption text-text-muted uppercase tracking-[0.12em]">
            9 yrs experience · £600K+ business value · 55 FTEs automated · 130K+ documents processed
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 01 / THE JOURNEY -->
  <section class="py-32 md:py-40 border-t border-border">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal>
        <SectionLabel index="01" label="The Journey" />
        <h2 class="font-display text-headline md:text-display text-text-primary max-w-2xl">
          From the desk to the model layer
        </h2>
        
        <p class="mt-6 text-body text-text-body max-w-prose">
          Three chapters. Each one taught me something the next chapter needed. The domain came first; the models came afterwards — and that's exactly why they worked.
        </p>
      </Reveal>
      
        {[
          {
            years: "2017 — 2019",
            title: "Reconciliation Analyst",
            org: "State Street Global Advisory",
            logo: "state-street",
            logoAlt: "State Street logo",
            logoClass: "h-7 w-auto max-w-[140px]",
            text: "Reconciled 100+ managed pension fund portfolios across equities, derivatives, FX, and post-trade settlement."
          },
          {
            years: "2019 — 2022",
            title: "Data Scientist",
            org: "London Stock Exchange Group",
            logo: "lseg",
            logoAlt: "LSEG logo",
            logoClass: "h-8 w-auto max-w-[120px]",
            text: "Moved from operations to automation — building NLP pipelines and ML systems for financial documents."
          },
          {
            years: "2022 — Present",
            title: "Senior Data Scientist",
            org: "London Stock Exchange Group",
            logo: "lseg",
            logoAlt: "LSEG logo",
            logoClass: "h-8 w-auto max-w-[120px]",
            text: "Leading GenAI and agentic systems that deliver £600K+ in production value across global workflows."
          }
        ].map((chapter, i) => (
          <Reveal delay={`${i * 80}ms`} as="article" class="group p-6 rounded-xl border border-border bg-transparent hover:bg-surface hover:border-border-strong transition-all duration-200">
            <p class="font-mono text-caption text-text-muted uppercase tracking-[0.12em]">{chapter.years}</p>
            <div class="mt-3 mb-2">
              <Logo name={chapter.logo} alt={chapter.logoAlt} class={chapter.logoClass} />
            </div>
            <h3 class="font-display text-title text-text-primary">{chapter.title}</h3>
            <p class="mt-1 font-mono text-caption text-text-muted">{chapter.org}</p>
            <p class="mt-4 text-body text-text-body leading-relaxed">{chapter.text}</p>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- 02 / PRINCIPLES -->
  <section class="py-32 md:py-40 border-t border-border">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal>
        <SectionLabel index="02" label="Principles" />
        <h2 class="font-display text-headline md:text-display text-text-primary max-w-2xl">
          What I believe
        </h2>
      </Reveal>
      
      <div class="mt-16 grid md:grid-cols-3 gap-6">
        {[
          {
            icon: "document",
            title: "Domain-first",
            text: "Models don't fail on syntax. They fail on context — the settlement logic, the regulatory nuance, the edge case that only shows up in month three."
          },
          {
            icon: "check",
            title: "Compliance-aware",
            text: "Every production system is source-referenced, auditable, and explainable. In finance, trust is the real deliverable."
          },
          {
            icon: "chart",
            title: "Outcome-driven",
            text: "I optimise for business value, not leaderboard scores. £600K+ delivered and 55 FTEs automated are the only metrics that matter."
          }
        ].map((p, i) => (
          <Reveal delay={`${i * 80}ms`} as="article" class="group p-6 rounded-xl border border-border bg-transparent hover:bg-surface hover:border-border-strong transition-all duration-200">
            <Icon name={p.icon} class="h-7 w-7 text-text-muted" size={28} />
            <div class="mt-6 pt-6 border-t border-border">
              <h3 class="font-display text-title text-text-primary">{p.title}</h3>
              <p class="mt-3 text-body text-text-body leading-relaxed">{p.text}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- 03 / PROOF -->
  <section class="py-32 md:py-40 border-t border-border">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal>
        <SectionLabel index="03" label="Proof" />
        <h2 class="font-display text-headline md:text-display text-text-primary max-w-2xl">
          Production work that proves the thesis
        </h2>
      </Reveal>
      
      <div class="mt-16 space-y-0">
        {[
          {
            number: "01",
            title: "GenAI Financial Data Extraction Pipeline",
            impact: "£350K+ saved · 50 FTE reduction"
          },
          {
            number: "02",
            title: "Korean Regulatory Filing Extraction",
            impact: "15 days → 40 minutes · 130K+ docs"
          }
        ].map((project, i) => (
          <Reveal delay={`${i * 80}ms`} as="article" class="group flex items-start gap-6 md:gap-10 py-8 border-b border-border hover:bg-surface transition-all duration-200">
            <span class="font-mono text-caption text-text-muted uppercase tracking-[0.12em] w-12 flex-shrink-0">{project.number}</span>
            <div class="flex-1">
              <h3 class="font-display text-title text-text-primary group-hover:text-text-body transition-colors">{project.title}</h3>
              <p class="mt-1 text-body text-text-muted">{project.impact}</p>
            </div>
            <Icon name="arrow-right" class="h-5 w-5 text-text-muted group-hover:text-text-primary transition-colors mt-1" size={20} />
          </Reveal>
        ))}
      </div>
      
      <Reveal delay="160ms" class="mt-12">
        <a href="/Portfolio_site/projects" class="inline-flex items-center gap-2 font-mono text-caption text-text-muted uppercase tracking-[0.12em] hover:text-text-primary transition-colors">
          View all projects
          <Icon name="arrow-right" class="h-4 w-4" size={16} />
        </a>
      </Reveal>
    </div>
  </section>

  <!-- 03.5 / FROM LINKEDIN -->
  <section class="py-32 md:py-40 border-t border-border">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal>
        <SectionLabel index="Field Notes" label="LinkedIn" />
        <h2 class="font-display text-headline md:text-display text-text-primary max-w-2xl">
          Latest writing on AI, LLMs, and systems
        </h2>
      </Reveal>

      <div class="mt-16 grid md:grid-cols-2 gap-6">
        {[
          {
            title: "How Gemma 4’s Built-In Draft Models Change Speculative Decoding",
            excerpt: "Gemma 4 ships Multi-Token Prediction and paired draft models as a first-class feature — removing the friction of finding, matching, and deploying separate drafters.",
            url: "https://www.linkedin.com/posts/abhilash-k-panda_how-gemma-4s-built-in-draft-models-change-share-7472509610080444417-_V8d/",
            tags: ["LLM", "Inference"]
          },
          {
            title: "LLM Inferencing is a Systems Engineering Challenge",
            excerpt: "Why serving LLMs at scale is a split-brain problem: prefill is compute-bound, decoding is memory-bandwidth-bound, and the KV cache is the hidden enemy.",
            url: "https://www.linkedin.com/posts/abhilash-k-panda_machinelearning-llm-generativeai-share-7470333782517002241-Ezuc/",
            tags: ["Systems Engineering", "LLM"]
          },
          {
            title: "LLM Evolution: From Attention to Memory Management",
            excerpt: "A 2017–2026 arc from Transformer self-attention through Flash Attention, MLA, CSA/HCA, and sparse retrieval — attention is becoming memory management.",
            url: "https://www.linkedin.com/posts/abhilash-k-panda_ai-llm-transformers-share-7469989736531587072-7eqV/",
            tags: ["Transformers", "Architecture"]
          },
          {
            title: "DeepSeek V4: Hierarchical Attention for Efficient Long-Context Retrieval",
            excerpt: "DeepSeek V4 tackles the economics of million-token context through CSA, HCA, and a token → compressed → global memory hierarchy.",
            url: "https://www.linkedin.com/posts/abhilash-k-panda_deepseek-llm-aiarchitecture-share-7469649021830131712-88ne/",
            tags: ["DeepSeek", "Long Context"]
          }
        ].map((post, i) => (
          <Reveal delay={`${i * 80}ms`} as="article" class="group p-6 rounded-xl border border-border bg-transparent hover:bg-surface hover:border-border-strong transition-all duration-200">
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="font-mono text-caption text-text-muted uppercase tracking-[0.12em]">{tag}</span>
              ))}
            </div>
            <h3 class="mt-4 font-display text-title text-text-primary group-hover:text-text-body transition-colors">{post.title}</h3>
            <p class="mt-3 text-body text-text-body leading-relaxed">{post.excerpt}</p>
            <a
              href={post.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-2 font-mono text-caption text-text-muted uppercase tracking-[0.12em] hover:text-text-primary transition-colors"
            >
              Read on LinkedIn
              <Icon name="external" class="h-4 w-4" size={16} />
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- 04 / NEXT -->
  <section class="py-32 md:py-40 border-t border-border">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal>
        <SectionLabel index="04" label="What's Next" />
        <h2 class="font-display text-headline md:text-display text-text-primary max-w-2xl">
          Bring the unfair advantage to your team
        </h2>
        
        <p class="mt-6 text-body text-text-body max-w-prose">
          Nine years in. I'm looking for senior IC and lead roles at the intersection of financial services and production AI — places where models are the product, not the slide deck.
        </p>
        
        <p class="mt-4 text-body text-text-body max-w-prose">
          If you need AI that understands settlement logic, regulatory nuance, and analyst workflows, let's talk.
        </p>
        
        <div class="mt-10 flex flex-wrap gap-4">
          <Button href="mailto:abhilash.k.panda@gmail.com" variant="primary">
            <Icon name="mail" class="h-4 w-4" size={16} />
            abhilash.k.panda@gmail.com
          </Button>
          <Button href="https://linkedin.com/in/abhilash-k-panda" target="_blank" rel="noopener noreferrer" variant="secondary">
            LinkedIn
            <Icon name="external" class="h-4 w-4" size={16} />
          </Button>
        </div>
      </Reveal>
    </div>
  </section>
</MainLayout>

---
import MainLayout from "../layout/MainLayout.astro";
import Icon from "../components/Icon.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";

const title = "Resume | Abhilash Kumar Panda";
const seoTitle = "Resume | Abhilash Kumar Panda";
const seoDesc = "Two versions: a general resume and an LSEG-tailored resume. Download PDF or view inline.";
---

<MainLayout title={title} seoTitle={seoTitle} seoDesc={seoDesc}>
  <section class="pt-32 md:pt-40 pb-16">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal>
        <h1 class="font-display text-headline md:text-display text-text-primary">Resume</h1>
        
        <p class="mt-4 text-body text-text-body max-w-prose">
          Two versions: a general resume focused on GenAI and financial AI leadership, and an LSEG-tailored resume highlighting production systems delivered inside the group.
        </p>
      </Reveal>

      <Reveal delay="80ms" class="mt-10">
        <div class="flex gap-8 border-b border-border">
          <button type="button" id="tab-general" class="tab-btn pb-3 font-mono text-caption uppercase tracking-[0.12em] text-text-primary border-b border-text-primary transition-colors" aria-pressed="true">
            General
          </button>
          <button type="button" id="tab-lseg" class="tab-btn pb-3 font-mono text-caption uppercase tracking-[0.12em] text-text-muted hover:text-text-primary border-b border-transparent transition-colors" aria-pressed="false">
            LSEG
          </button>
        </div>
      </Reveal>

      <Reveal delay="160ms" class="mt-8">
        <div id="actions-general" class="flex flex-wrap gap-4">
          <Button href="/Portfolio_site/resume.pdf" download="Abhilash_Kumar_Panda_Resume.pdf" variant="primary">
            <Icon name="download" class="h-4 w-4" size={16} />
            Download PDF
          </Button>
          <Button href="/Portfolio_site/resume.pdf" target="_blank" rel="noopener noreferrer" variant="secondary">
            Open in new tab
            <Icon name="external" class="h-4 w-4" size={16} />
          </Button>
        </div>

        <div id="actions-lseg" class="flex flex-wrap gap-4 hidden">
          <Button href="/Portfolio_site/lseg_resume.pdf" download="Abhilash_Kumar_Panda_LSEG_Resume.pdf" variant="primary">
            <Icon name="download" class="h-4 w-4" size={16} />
            Download LSEG Resume
          </Button>
        </div>
      </Reveal>
    </div>
  </section>

  <section class="pb-24 md:pb-32">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
      <Reveal delay="240ms">
        <div class="pdf-container rounded-2xl overflow-hidden border border-border" id="viewer-general">
          <iframe src="/Portfolio_site/resume.pdf#toolbar=0&navpanes=0" class="w-full rounded-2xl" style="min-height: 85vh; border: none;" title="Abhilash Kumar Panda — General Resume"></iframe>
        </div>

        <div class="pdf-container rounded-2xl overflow-hidden border border-border hidden" id="viewer-lseg">
          <iframe src="/Portfolio_site/lseg_resume.pdf#toolbar=0&navpanes=0" class="w-full rounded-2xl" style="min-height: 85vh; border: none;" title="Abhilash Kumar Panda — LSEG Resume"></iframe>
        </div>
      </Reveal>
    </div>
  </section>

  <script is:inline>
    (function() {
      function switchTab(tabName) {
        const isGeneral = tabName === 'general';
        const generalViewer = document.getElementById('viewer-general');
        const lsegViewer = document.getElementById('viewer-lseg');
        const generalActions = document.getElementById('actions-general');
        const lsegActions = document.getElementById('actions-lseg');
        const generalTab = document.getElementById('tab-general');
        const lsegTab = document.getElementById('tab-lseg');

        if (generalViewer && lsegViewer) {
          generalViewer.classList.toggle('hidden', !isGeneral);
          lsegViewer.classList.toggle('hidden', isGeneral);
        }

        if (generalActions && lsegActions) {
          generalActions.classList.toggle('hidden', !isGeneral);
          lsegActions.classList.toggle('hidden', isGeneral);
        }

        if (generalTab) {
          generalTab.classList.toggle('text-text-primary', isGeneral);
          generalTab.classList.toggle('text-text-muted', !isGeneral);
          generalTab.classList.toggle('border-text-primary', isGeneral);
          generalTab.classList.toggle('border-transparent', !isGeneral);
          generalTab.setAttribute('aria-pressed', String(isGeneral));
        }

        if (lsegTab) {
          lsegTab.classList.toggle('text-text-primary', !isGeneral);
          lsegTab.classList.toggle('text-text-muted', isGeneral);
          lsegTab.classList.toggle('border-text-primary', !isGeneral);
          lsegTab.classList.toggle('border-transparent', isGeneral);
          lsegTab.setAttribute('aria-pressed', String(!isGeneral));
        }
      }

      document.getElementById('tab-general')?.addEventListener('click', function() { switchTab('general'); });
      document.getElementById('tab-lseg')?.addEventListener('click', function() { switchTab('lseg'); });
    })();
  </script>
</MainLayout>
